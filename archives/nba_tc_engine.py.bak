#!/usr/bin/env python3
"""
NBA TC Engine v5.0 — Full-Stat Player Props Engine
===================================================
Covers ALL four prop categories per player:
  • Points (PTS)
  • Rebounds (REB)
  • Assists (AST)
  • 3-Point Shots Made (3PM)

TC Formula:
  TC stat = stat × 0.85  (ACTIVE)
          = stat × 0.55  (Q — reduced further from 0.65)
          = 0            (OUT)

TC Target (T) = floor(TC stat × 0.88)
  → T is your conservative floor for each stat category
  → Bet UNDER when T < Market Line with edge ≥ +3.0 and hit_rate ≥ 75%

Game Total:
  TC_final = raw_combined_PTS × VAR_FACTOR (when spread provided)
           = raw_combined_PTS + PACE_ADJ    (no spread)
  TC_Line  = round(TC_final + K_GAP, 1)
  K_GAP    = 9.3  (historical gap between TC final and market total)

Signal: OVER when actual_total > TC_Line
       UNDER when actual_total < TC_Line
"""

from dataclasses import dataclass, field
from typing import List, Dict, Any, Optional
import argparse
import json

# ── CONSTANTS ────────────────────────────────────────────────────────────────
CONS_PTS     = 0.85   # conservative multiplier for all stat categories
Q_MULT       = 0.55   # questionable reduction
OUT_MULT     = 0.0    # out = zero
LINE_FACTOR  = 0.88    # derive game line from TC final
K_GAP        = 9.3    # historical gap between TC final and market total
VAR_LOW      = 0.76    # pace adjustment when spread is small
VAR_HIGH     = 0.82    # pace adjustment when spread is large (≥8 pts)
PACE_ADJ     = 8.0    # flat pace adjustment when no spread
MIN_EDGE     = 3.0    # minimum edge (L − T) to consider a prop valid
MIN_HIT_RATE = 0.75   # 75% historical hit rate minimum
KELLY_FRAC   = 0.25   # Kelly fraction for bet sizing
MIN_KELLY    = 0.01   # minimum Kelly fraction

# ── PLAYER ──────────────────────────────────────────────────────────────────
@dataclass
class Player:
    name:   str
    pos:    str
    ht:     str
    pts:    float
    reb:    float
    ast:    float
    tpm:    float     # 3-point shots made
    status: str = "ACTIVE"   # ACTIVE | Q | OUT

    def tc_raw(self, stat: float) -> float:
        if self.status == "OUT":
            return 0.0
        c = stat * CONS_PTS
        return round(c * Q_MULT, 1) if self.status == "Q" else round(c, 1)

    def tc_target(self, stat: float) -> int:
        return int(self.tc_raw(stat) * LINE_FACTOR)

    def proj(self) -> Dict[str, Any]:
        return {
            "TC_PTS":  self.tc_raw(self.pts),
            "TC_REB":  self.tc_raw(self.reb),
            "TC_AST":  self.tc_raw(self.ast),
            "TC_3PM": self.tc_raw(self.tpm),
            "T_PTS":   self.tc_target(self.pts),
            "T_REB":   self.tc_target(self.reb),
            "T_AST":   self.tc_target(self.ast),
            "T_3PM":   self.tc_target(self.tpm),
            "STATUS":  self.status,
        }


# ── TEAM ────────────────────────────────────────────────────────────────────
@dataclass
class Team:
    code:    str
    name:    str
    players: List[Player] = field(default_factory=list)
    injury_notes: List[str] = field(default_factory=list)

    def add(self, p: Player):
        self.players.append(p)

    def starters(self) -> List[Player]:
        return [p for p in self.players if p.status != "OUT"][:5]

    def bench(self) -> List[Player]:
        start_names = {p.name for p in self.starters()}
        return [p for p in self.players if p.name not in start_names and p.status != "OUT"]

    def active(self) -> List[Player]:
        return [p for p in self.players if p.status != "OUT"]

    def _sum_tc(self, key: str) -> float:
        return round(sum(p.proj()[key] for p in self.active()), 1)

    def totals(self) -> Dict[str, float]:
        return {
            "TC_PTS":  self._sum_tc("TC_PTS"),
            "TC_REB":  self._sum_tc("TC_REB"),
            "TC_AST":  self._sum_tc("TC_AST"),
            "TC_3PM":  self._sum_tc("TC_3PM"),
        }

    def bench_totals(self) -> Dict[str, float]:
        bench = self.bench()
        return {
            "TC_PTS":  round(sum(p.proj()["TC_PTS"] for p in bench), 1),
            "TC_REB":  round(sum(p.proj()["TC_REB"] for p in bench), 1),
            "TC_AST":  round(sum(p.proj()["TC_AST"] for p in bench), 1),
            "TC_3PM":  round(sum(p.proj()["TC_3PM"] for p in bench), 1),
        }


# ── GAME ────────────────────────────────────────────────────────────────────
class Game:
    def __init__(self, away_code: str, home_code: str,
                 sport: str = "NBA",
                 market_total: float = None,
                 market_spread: float = None,
                 prop_lines: Dict[str, Dict[str, float]] = None,
                 bankroll: float = 1000):
        self.away_code     = away_code
        self.home_code    = home_code
        self.sport        = sport
        self.market_total = market_total
        self.market_spread = market_spread
        self.prop_lines   = prop_lines or {}
        self.bankroll     = bankroll

        self.away = self._build_team(away_code)
        self.home = self._build_team(home_code)

    def _build_team(self, code: str) -> Team:
        rosters = NBA_ROSTERS if self.sport == "NBA" else WNBA_ROSTERS
        teams_map = NBA_TEAMS if self.sport == "NBA" else WNBA_TEAMS
        t = Team(code, teams_map.get(code, code))
        for p_data in rosters.get(code, []):
            t.add(Player(*p_data))
        return t

    def _tc_raw_combined(self) -> float:
        return round(self.away.totals()["TC_PTS"] + self.home.totals()["TC_PTS"], 1)

    def _tc_final(self) -> float:
        raw = self._tc_raw_combined()
        if self.market_spread is not None:
            factor = VAR_HIGH if abs(self.market_spread) >= 8 else VAR_LOW
            return round(raw * factor, 1)
        return round(raw + PACE_ADJ, 1)

    def _tc_line(self) -> float:
        tc_final = self._tc_final()
        return round(tc_final + K_GAP, 1)

    def _tc_edge(self) -> float:
        if self.market_total is None:
            return 0.0
        return round(self._tc_line() - self.market_total, 1)

    def _signal(self) -> str:
        return "UNDER" if self._tc_edge() > 0 else "OVER"

    def _kelly_bet(self) -> float:
        edge = self._tc_edge()
        if edge <= 0:
            return 0.0
        odds = 110
        implied = odds / 100.0
        k = KELLY_FRAC * abs(edge) / (implied - 1)
        return max(round(k, 4), MIN_KELLY if abs(edge) >= MIN_EDGE else 0)

    def get_tc_line(self)  -> float: return self._tc_line()
    def get_tc_final(self) -> float: return self._tc_final()
    def get_signal(self)   -> str:   return self._signal()
    def get_edge(self)     -> float: return self._tc_edge()

    def full_report(self):
        self._print_game_header()
        self._print_totals_section()
        self._print_starting_lineup_table(self.away, "AWAY", self.away_code)
        self._print_starting_lineup_table(self.home, "HOME", self.home_code)
        self._print_player_props_section(self.away)
        self._print_player_props_section(self.home)
        self._print_system_summary()

    def _print_game_header(self):
        print(f"\n{'═'*80}")
        print(f"  🏀  {self.away.name}  @  {self.home.name}  |  TC v5.0 FULL STAT PROPS")
        print(f"{'═'*80}")
        if self.market_total:
            print(f"  Market Total: {self.market_total}   |   TC Line: {self.get_tc_line()}   |   Edge: {self.get_edge():+.1f}")
        if self.market_spread is not None:
            print(f"  Market Spread: {self.market_spread:+.1f}   |   TC Final: {self.get_tc_final()}")
        print(f"  Signal: {self.get_signal()}  |  Kelly%: {self._kelly_bet()*100:.1f}%  |  Bankroll: ${self.bankroll:,.0f}")
        print(f"{'─'*80}")

    def _print_totals_section(self):
        aw_tot  = self.away.totals()
        hm_tot  = self.home.totals()
        aw_bench = self.away.bench_totals()
        hm_bench = self.home.bench_totals()

        print(f"\n  TEAM TOTALS BREAKDOWN")
        print(f"  {'Category':<10} {'AWAY TC':>10} {'HOME TC':>10} {'COMBINED':>10}")
        print(f"  {'-'*42}")
        for cat in ["TC_PTS", "TC_REB", "TC_AST", "TC_3PM"]:
            label = cat.replace("TC_", "")
            aw_v = aw_tot[cat]
            hm_v = hm_tot[cat]
            combined = round(aw_v + hm_v, 1)
            print(f"  {label:<10} {aw_v:>10.1f} {hm_v:>10.1f} {combined:>10.1f}")

        print(f"\n  BENCH TOTALS")
        print(f"  {'Category':<10} {'AWAY BENCH':>12} {'HOME BENCH':>12}")
        print(f"  {'-'*36}")
        for cat in ["TC_PTS", "TC_REB", "TC_AST", "TC_3PM"]:
            label = cat.replace("TC_", "")
            print(f"  {label:<10} {aw_bench[cat]:>12.1f} {hm_bench[cat]:>12.1f}")

        print(f"\n  GAME TC SUMMARY")
        tc_raw   = self._tc_raw_combined()
        tc_final = self.get_tc_final()
        tc_line  = self.get_tc_line()
        factor_lbl = "VAR_HIGH" if self.market_spread and abs(self.market_spread) >= 8 else "VAR_LOW/PACE"
        print(f"  Raw Combined TC PTS:  {tc_raw:.1f}")
        print(f"  TC Final (adj):       {tc_final:.1f}  ({factor_lbl})")
        print(f"  TC Line:              {tc_line:.1f}  (TC_final + K={K_GAP})")
        if self.market_total:
            edge = self.get_edge()
            arrow = "↑" if edge > 0 else "↓"
            print(f"  Market Total:         {self.market_total}   |   Edge: {edge:+.1f} {arrow}")
        print(f"{'─'*80}")

    def _print_starting_lineup_table(self, team: Team, label: str, code: str):
        starters = team.starters()
        bench    = team.bench()

        print(f"\n  {label} ({code}) — STARTING LINEUP (5)")
        print(f"  {'Player':<22} {'POS':>4} {'HT':>5} "
              f"{'TC_PTS':>7} {'TC_REB':>7} {'TC_AST':>7} {'TC_3PM':>7}  "
              f"{'T_PTS':>6} {'T_REB':>6} {'T_AST':>6} {'T_3PM':>6} "
              f"{'STATUS':>6}")
        print(f"  {'-'*105}")
        for p in starters:
            proj = p.proj()
            flag = "⚠️ Q" if p.status == "Q" else ("❌ OUT" if p.status == "OUT" else "✅ OK")
            print(f"  {p.name:<22} {p.pos:>4} {p.ht:>5} "
                  f"{proj['TC_PTS']:>7.1f} {proj['TC_REB']:>7.1f} {proj['TC_AST']:>7.1f} {proj['TC_3PM']:>7.1f}  "
                  f"{proj['T_PTS']:>6} {proj['T_REB']:>6} {proj['T_AST']:>6} {proj['T_3PM']:>6} "
                  f"{flag:>6}")

        bench_t = team.bench_totals()
        print(f"  {'─'*105}")
        print(f"  {'BENCH TOTAL':22} {'':<4} {'':<5} "
              f"{bench_t['TC_PTS']:>7.1f} {bench_t['TC_REB']:>7.1f} {bench_t['TC_AST']:>7.1f} {bench_t['TC_3PM']:>7.1f}  "
              f"{'':>6} {'':>6} {'':>6} {'':>6}")

        team_t = team.totals()
        print(f"  {'TEAM TOTAL':22} {'':<4} {'':<5} "
              f"{team_t['TC_PTS']:>7.1f} {team_t['TC_REB']:>7.1f} {team_t['TC_AST']:>7.1f} {team_t['TC_3PM']:>7.1f}")

    def _print_player_props_section(self, team: Team):
        print(f"\n  PLAYER PROPS — {team.name} ({team.code}) — PTS | REB | AST | 3PM")
        print(f"  TC = stat×{CONS_PTS} | Q×{Q_MULT} | T = floor(TC×{LINE_FACTOR})")
        print(f"  Valid: EDGE(L−T)≥{MIN_EDGE}  |  BET: UNDER when T < L")
        print(f"  {'Player':<22} {'POS':>4} {'STAT':>4} "
              f"{'L':>6} {'T':>6} {'E':>6} {'VALID?':>7} "
              f"{'L':>6} {'T':>6} {'E':>6} {'VALID?':>7} "
              f"{'L':>6} {'T':>6} {'E':>6} {'VALID?':>7} "
              f"{'L':>6} {'T':>6} {'E':>6} {'VALID?':>7}")
        print(f"  {'-'*150}")

        for p in team.active():
            proj = p.proj()
            flag = "⚠️Q" if p.status == "Q" else "✅"

            lines = self.prop_lines.get(p.name, {})
            L_pts = lines.get("PTS", p.pts)
            L_reb = lines.get("REB", p.reb)
            L_ast = lines.get("AST", p.ast)
            L_3pm = lines.get("3PM", p.tpm)

            T_pts, T_reb, T_ast, T_3pm = proj["T_PTS"], proj["T_REB"], proj["T_AST"], proj["T_3PM"]
            E_pts = L_pts - T_pts
            E_reb = L_reb - T_reb
            E_ast = L_ast - T_ast
            E_3pm = L_3pm - T_3pm

            v_pts = "✅" if E_pts >= MIN_EDGE else "⚠️ "
            v_reb = "✅" if E_reb >= MIN_EDGE else "⚠️ "
            v_ast = "✅" if E_ast >= MIN_EDGE else "⚠️ "
            v_3pm = "✅" if E_3pm >= MIN_EDGE else "⚠️ "

            # Print one row per stat category (PTS / REB / AST / 3PM)
            for cat, L, T, E, v in [("PTS",L_pts,T_pts,E_pts,v_pts),
                                      ("REB",L_reb,T_reb,E_reb,v_reb),
                                      ("AST",L_ast,T_ast,E_ast,v_ast),
                                      ("3PM",L_3pm,T_3pm,E_3pm,v_3pm)]:
                marker = "  " if cat != "PTS" else f"  {p.name:<22} {p.pos:>4} {flag:>4}"
                print(f"  {marker} {cat:>4} "
                      f"{L:>6.1f} {T:>6d} {E:>+6.1f} {v:>7}", end="")
                if cat == "3PM":
                    print()  # end the row

        print(f"  {'─'*150}")
        print(f"  LEGEND: L=Market Line | T=TC Target (conservative floor) | E=Edge (L−T) | ✅=Valid(Edge≥{MIN_EDGE}) | ⚠️=Below threshold")
        print(f"  BET: UNDER when T < L with Edge ≥ {MIN_EDGE} → TC floor sits below market, giving you edge")

    def _print_system_summary(self):
        print(f"\n{'═'*80}")
        print(f"  TC SYSTEM SUMMARY — {self.away.code} @ {self.home.code}")
        print(f"{'═'*80}")
        if self.market_total:
            tc_line = self.get_tc_line()
            mkt = self.market_total
            diff = self.get_edge()
            print(f"  Game Total:   TC_Line={tc_line:.1f}  |  Market={mkt:.1f}  |  Edge={diff:+.1f}")
            print(f"  Signal: {self.get_signal()}  |  Bet: OVER if actual>{tc_line:.1f}  |  UNDER if actual<{tc_line:.1f}")
        print(f"\n  TC FORMULA REFERENCE:")
        print(f"    Player TC  = stat × {CONS_PTS} (ACTIVE) | × {Q_MULT} (Q) | × {OUT_MULT} (OUT)")
        print(f"    Player T   = floor(TC × {LINE_FACTOR})")
        print(f"    Game TC_Final = raw_PTS × {VAR_HIGH} (spread≥8) or ×{VAR_LOW} (spread<8) or +{PACE_ADJ} (no spread)")
        print(f"    Game TC_Line  = TC_Final + K={K_GAP}")
        print(f"{'═'*80}\n")

    def to_dict(self) -> Dict[str, Any]:
        return {
            "matchup":      f"{self.away_code} @ {self.home_code}",
            "sport":        self.sport,
            "market_total": self.market_total,
            "market_spread": self.market_spread,
            "tc_final":     self.get_tc_final(),
            "tc_line":      self.get_tc_line(),
            "signal":       self.get_signal(),
            "edge":         self.get_edge(),
            "kelly_pct":    self._kelly_bet() * 100,
            "away_totals":  self.away.totals(),
            "home_totals":  self.home.totals(),
            "away_players": [{**{"name":p.name,"pos":p.pos,"ht":p.ht,"status":p.status}, **p.proj()}
                             for p in self.away.active()],
            "home_players": [{**{"name":p.name,"pos":p.pos,"ht":p.ht,"status":p.status}, **p.proj()}
                             for p in self.home.active()],
        }


# ── HELPER ───────────────────────────────────────────────────────────────────
def _p(name, pos, ht, pts, reb, ast, tpm, status="ACTIVE"):
    return (name, pos, ht, pts, reb, ast, tpm, status)


