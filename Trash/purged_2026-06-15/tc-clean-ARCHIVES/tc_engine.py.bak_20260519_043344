TEAM_REGISTRY = {"NBA": NBA_TEAMS, "WNBA": WNBA_TEAMS}

def get_teams(sport: str) -> Dict[str, Team]:
    return TEAM_REGISTRY.get(sport.upper(), NBA_TEAMS)

def get_team(abbr: str, sport: str = "NBA") -> Team:
    teams = get_teams(sport)
    abbr = abbr.upper()
    if abbr not in teams:
        raise ValueError(f"Unknown {sport} team: {abbr}. Available: {list(teams.keys())}")
    return teams[abbr]

# ── TC Core Math ──────────────────────────────────────────────────────────────

def calc_tc(player: Player) -> float:
    """Single-player TC points."""
    return player.tc_pts()

def calc_team_tc(team: Team) -> Dict[str, float]:
    """Team TC breakdown: starters, bench, total."""
    return {
        "tc_total":    team.tc_total(),
        "tc_starters": team.tc_starters(),
        "bench_total": team.bench_total(),
    }

def _hit_rate(edge: float, hr_tiers=None) -> float:
    """Convert edge gap to hit-rate probability."""
    if hr_tiers is None:
        hr_tiers = ((10, 0.72), (7, 0.68), (5, 0.64), (3, 0.60), (0, 0.57))
    for threshold, rate in hr_tiers:
        if abs(edge) >= threshold:
            return rate
    return 0.57

def _kelly(bankroll: float, edge: float, odds: int = -110,
           fraction: float = KELLY_FRAC) -> float:
    """Kelly stake = bankroll × Kelly fraction."""
    if edge <= 0:
        return 0.0
    b = abs(odds) / 100 if odds > 0 else 100 / abs(odds)
    p = min(0.72, 0.52 + min(edge, 10) * 0.02)
    q  = 1 - p
    kelly = (b * p - q) / b if b > 0 else 0.0
    return round(max(0.0, bankroll * kelly * fraction), 2)

# ── Game Projection ──────────────────────────────────────────────────────────

def calc_game(
    home: Team,
    away: Team,
    market_total: float,
    market_spread: float,
    sport: str = "NBA",
) -> Dict[str, Any]:
    """Full game projection with edge, lean, and spread analysis."""
    w_factor = W_FACTOR.get(sport.upper(), 0.912)

    h_tc  = home.tc_total()
    a_tc  = away.tc_total()

    raw_total   = round(h_tc + a_tc, 1)
    cal_total   = round(raw_total / w_factor, 1)
    edge        = round(cal_total - market_total, 1)

    home_line   = round(h_tc * LINE_FACTOR)
    away_line   = round(a_tc * LINE_FACTOR)
    tc_spread   = round(home_line - away_line, 1)

    total_lean  = "OVER" if edge > 3 else ("UNDER" if edge < -3 else "PASS")
    spread_abs  = abs(market_spread)
    tc_favored  = "HOME" if tc_spread > 0 else "AWAY"
    spread_lean = "HOME" if tc_spread > spread_abs else (
                  "AWAY" if tc_spread < -spread_abs else "PASS")

    return {
        "home":         home.as_dict(),
        "away":         away.as_dict(),
        "tc_raw":       {"home": h_tc, "away": a_tc, "combined": raw_total},
        "tc_cal":       {"cal_total": cal_total, "w_factor": w_factor},
        "edge":         edge,
        "market_total": market_total,
        "total_lean":   total_lean,
        "tc_spread":    tc_spread,
        "market_spread": market_spread,
        "spread_lean":  spread_lean,
        "tc_favored":   tc_favored,
        "lines":        {"home_line": home_line, "away_line": away_line},
    }

# ── Betting Stakes ────────────────────────────────────────────────────────────

def build_bets(
    home_abbr: str,
    away_abbr: str,
    market_total: float,
    market_spread: float,
    bankroll: float = 1000.0,
    sport: str = "NBA",
) -> Dict[str, Any]:
    """Build bet legs from a game projection. Returns stake info and legs."""
    teams = get_teams(sport)
    home  = teams[home_abbr.upper()]
    away  = teams[away_abbr.upper()]

    proj  = calc_game(home, away, market_total, market_spread, sport)
    edge  = proj["edge"]
    w_factor = W_FACTOR.get(sport.upper(), 0.912)

    # ── Total bet ──────────────────────────────────────────────────────────
    if abs(edge) < 3:
        total_leg  = None
        total_bet  = "PASS"
        stake_total = 0.0
        unit_total  = 0.0
    else:
        unit_total  = round(abs(edge) * 0.20, 2)
        stake_total = round(unit_total * bankroll / 100, 2)
        total_bet   = "OVER" if edge > 0 else "UNDER"
        total_leg   = {
            "pick":  f"{total_bet} {market_total}",
            "type":  "total",
            "edge":  edge,
            "units": unit_total,
            "stake": stake_total,
            "to_win": round(stake_total * 1.91, 2),
        }

    # ── Spread bet ─────────────────────────────────────────────────────────
    if proj["spread_lean"] == "PASS":
        spread_leg  = None
        stake_spread = 0.0
    else:
        spread_edge = round(proj["tc_spread"] - abs(market_spread), 1)
        stake_spread = round(bankroll * 0.01, 2)
        spread_leg = {
            "pick":  f"{home_abbr.upper()} {proj['tc_spread']:+.1f}",
            "type":  "spread",
            "edge":  spread_edge,
            "units": 1.0,
            "stake": stake_spread,
            "to_win": round(stake_spread * 1.91, 2),
        }

    legs = [l for l in [total_leg, spread_leg] if l]
    total_stake = round(stake_total + stake_spread, 2)

    return {
        "bankroll":   bankroll,
        "total_stake": total_stake,
        "legs":       legs,
        "sport":      sport,
        "w_factor":   w_factor,
    }

def project_game(
    home_abbr: str,
    away_abbr: str,
    market_total: float,
    market_spread: float,
    series: str = "",
    game_time: str = "TBD",
    bankroll: float = 1000.0,
    sport: str = "NBA",
) -> Dict[str, Any]:
    """Full structured game projection with betting recommendations."""
    teams = get_teams(sport)
    home  = teams[home_abbr.upper()]
    away  = teams[away_abbr.upper()]

    proj  = calc_game(home, away, market_total, market_spread, sport)
    bets  = build_bets(home_abbr, away_abbr, market_total, market_spread,
                        bankroll, sport)

    return {
        "meta": {
            "home":      home_abbr.upper(),
            "away":      away_abbr.upper(),
            "series":    series,
            "game_time": game_time,
            "sport":     sport,
            "w_factor":  W_FACTOR.get(sport.upper(), 0.912),
        },
        "tc": {
            "home_tc":       proj["home"]["tc_total"],
            "away_tc":       proj["away"]["tc_total"],
            "tc_raw_combined": proj["tc_raw"]["combined"],
            "tc_cal_combined": proj["tc_cal"]["cal_total"],
            "edge":          proj["edge"],
            "market_total":  market_total,
            "total_lean":    proj["total_lean"],
        },
        "starters": {
            "home": proj["home"]["players"][:5],
            "away": proj["away"]["players"][:5],
        },
        "bench": {
            "home": round(proj["home"]["tc_total"] - proj["home"]["tc_starters"], 1),
            "away": round(proj["away"]["tc_total"] - proj["away"]["tc_starters"], 1),
        },
        "injuries": {
            "home": proj["home"]["injury_notes"],
            "away": proj["away"]["injury_notes"],
        },
        "spread": {
            "tc_spread":     proj["tc_spread"],
            "market_spread": market_spread,
            "lean":          proj["spread_lean"],
            "tc_favored":    proj["tc_favored"],
        },
        "bets": bets,
    }

# ── Backtest ─────────────────────────────────────────────────────────────────

BACKTEST_GAMES = [
    # NBA Apr 19
    {"home": "BOS", "away": "PHI", "date": "2026-04-19",
     "market_total": 208.5, "market_spread": -11.5,
     "actual_total": 216, "actual_winner": "BOS"},
    {"home": "DEN", "away": "LAC", "date": "2026-04-19",
     "market_total": 216.5, "market_spread": -4.5,
     "actual_total": 222, "actual_winner": "DEN"},
    {"home": "DET", "away": "ORL", "date": "2026-04-19",
     "market_total": 200.5, "market_spread": -5.5,
     "actual_total": 207, "actual_winner": "DET"},
    {"home": "SA",  "away": "POR", "date": "2026-04-19",
     "market_total": 206.5, "market_spread": -8.5,
     "actual_total": 226, "actual_winner": "SA"},
]

def run_backtest(sport: str = "NBA") -> Dict[str, Any]:
    teams = get_teams(sport)
    results = []
    for g in BACKTEST_GAMES:
        home = teams[g["home"]]
        away = teams[g["away"]]
        proj = calc_game(home, away, g["market_total"], g["market_spread"], sport)

        edge        = proj["edge"]
        cal_total   = proj["tc_cal"]["cal_total"]
        actual      = g["actual_total"]

        total_hit   = ("OVER" if edge > 0 else "UNDER") == (
                      "OVER" if actual > g["market_total"] else "UNDER")

        tc_spred    = proj["tc_spread"]
        mkt_spread  = g["market_spread"]
        # tc_spread > 0 means home TC line > away TC line → HOME favored
        # Correct spread hit: TC's favored side must match actual winner
        tc_favored_home = tc_spred > 0
        actual_is_home   = g["actual_winner"] == g["home"]
        spread_hit  = tc_favored_home == actual_is_home

        parlay_hit  = total_hit and spread_hit

        results.append({
            "game":         f"{g['away']} @ {g['home']}",
            "date":         g["date"],
            "tc_total":     cal_total,
            "market_total": g["market_total"],
            "actual_total": actual,
            "edge":         edge,
            "total_lean":   proj["total_lean"],
            "total_hit":    total_hit,
            "tc_spread":    tc_spred,
            "market_spread": mkt_spread,
            "tc_favored":   tc_favored_home,
            "actual_winner": g["actual_winner"],
            "spread_hit":   spread_hit,
            "parlay_hit":   parlay_hit,
        })

    n = len(results)
    total_hr   = round(sum(r["total_hit"] for r in results) / n * 100, 1)
    spread_hr  = round(sum(r["spread_hit"] for r in results) / n * 100, 1)
    parlay_hr  = round(sum(r["parlay_hit"] for r in results) / n * 100, 1)
    avg_edge   = round(sum(r["edge"] for r in results) / n, 1)

    return {
        "games":   results,
        "summary": {
            "sport":           sport,
            "total_games":     n,
            "total_hit_rate":  total_hr,
            "spread_hit_rate": spread_hr,
            "parlay_hit_rate": parlay_hr,
            "avg_edge":        avg_edge,
            "w_factor":        W_FACTOR.get(sport.upper(), 0.912),
        },
    }

