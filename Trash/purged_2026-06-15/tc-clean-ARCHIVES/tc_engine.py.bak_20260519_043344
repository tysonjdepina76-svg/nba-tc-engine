"""
tc_engine.py — Triple Conservative Betting Engine
==================================================
Unified NBA + WNBA TC engine. Single source of truth.

TC Formula:
    TC_pts  = (pts + reb + ast + tpm) × 0.85 × status_factor
    status: ACTIVE×1.0 | Q×0.55 | OUT×0.0
    Line    = TC_pts × 0.88
    Edge    = TC_cal − market_total
    TC_cal  = TC_raw / W_factor   (NBA=0.912 | WNBA=0.934)

Usage:
    python tc_engine.py --backtest
    python tc_engine.py --game "PHI @ BOS" --total 208.5 --spread -11.5
    python tc_engine.py --list-teams
    python tc_engine.py --sport WNBA --game "MIN @ DAL"

API:
    uvicorn tc_engine:app --host 0.0.0.0 --port 8001
"""

from dataclasses import dataclass, field
from typing import List, Dict, Any, Optional
import argparse
import json
import math

# ── Constants ────────────────────────────────────────────────────────────────

CONS_PTS   = 0.85   # conservative points weight
CONS_REB   = 0.12   # rebound contribution weight
CONS_AST   = 0.10   # assist contribution weight
CONS_3PM   = 0.08   # 3pm contribution weight
LINE_FACTOR= 0.88   # line derivation from TC
Q_FACTOR   = 0.55   # questionable status reduction
OUT_FACTOR = 0.0   # out status = zero contribution
MIN_EDGE   = 1.0    # minimum edge to bet

W_FACTOR   = {"NBA": 0.912, "WNBA": 0.934}

KELLY_FRAC = 0.50   # Kelly fraction for stake sizing
MIN_HR     = 0.57   # minimum hit-rate threshold

# Odds lookup for standard -110 / +260
ODDS = {"standard": -110, "parlay_2": -110, "parlay_3": +260}

# ── Data Models ─────────────────────────────────────────────────────────────

@dataclass
class Player:
    name: str
    pos: str
    ht: str
    pts: float
    reb: float
    ast: float
    tpm: float
    status: str = "ACTIVE"

    def tc_pts(self) -> float:
        factor = {"ACTIVE": 1.0, "Q": Q_FACTOR, "OUT": OUT_FACTOR}.get(self.status, 1.0)
        return round((self.pts + self.reb + self.ast + self.tpm) * CONS_PTS * factor, 1)

    def as_dict(self) -> dict:
        return {
            "name":   self.name,
            "pos":    self.pos,
            "ht":     self.ht,
            "tc_pts": self.tc_pts(),
            "status": self.status,
            "raw":    {"pts": self.pts, "reb": self.reb, "ast": self.ast, "tpm": self.tpm},
        }

@dataclass
class Team:
    abbr: str
    name: str
    players: List[Player]
    injury_notes: List[str] = field(default_factory=list)

    def tc_total(self) -> float:
        return round(sum(p.tc_pts() for p in self.players), 1)

    def tc_starters(self) -> float:
        return round(sum(p.tc_pts() for p in self.players[:5]), 1)

    def bench_total(self) -> float:
        bench = self.players[5:]
        return round(sum(p.tc_pts() for p in bench), 1) if bench else 0.0

    def active_players(self) -> List[Player]:
        return [p for p in self.players if p.status != "OUT"]

    def as_dict(self) -> dict:
        return {
            "abbr":    self.abbr,
            "name":    self.name,
            "tc_total": self.tc_total(),
            "tc_starters": self.tc_starters(),
            "bench_total": self.bench_total(),
            "players":    [p.as_dict() for p in self.players],
            "injury_notes": self.injury_notes,
        }

# ── Rosters ─────────────────────────────────────────────────────────────────

def _P(name, pos, ht, pts, reb, ast, tpm, status="ACTIVE"):
    return Player(name, pos, ht, pts, reb, ast, tpm, status)

