# TC Sports App — Environment Variables
# Copy to .env and fill in your values

# TheOddsAPI (for betting lines)
THEODDSAPI=toa_live_t5d8p3n1

# SportsGameOdds API
SGO_API_KEY=

# DeepSeek API (for reasoning/analysis)
DEEPSEEK_API_KEY=

# PostgreSQL
DB_HOST=postgres
DB_NAME=tc_engine
DB_USER=tc_user
DB_PASSWORD=secure

# Server
API_PORT=8000
DASHBOARD_PORT=8501

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin
