# TC Engine Environment Configuration
# Copy to .env and fill in values — NEVER commit .env to git

# Sports Data APIs
THEODDSAPI_KEY=your_theoddsapi_key_here
SPORTRADAR_KEY=your_sportradar_key_here
SGO_API_KEY=your_sportsdataio_key_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tc_engine

# Email (Gmail SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_TO=recipient@email.com

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Dashboard
DASHBOARD_PORT=8510

# Cron Schedule (default: 1:20 AM ET daily)
SCHEDULE_HOUR=1
SCHEDULE_MINUTE=20
