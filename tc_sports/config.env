# TC Sports Pipeline Configuration
# Source this before running: source /home/workspace/tc_sports/config.env

export TC_BASE=/home/workspace/tc_sports
export TC_DATA=/home/workspace/data
export TC_DAILY_LOG=/home/workspace/Daily_Log
export TC_PICKS_DB=/home/workspace/Projects/data/tc_pipeline.db

export TC_ALERTS=$TC_DATA/processed/alerts.json
export TC_ALERTS_CSV=$TC_DATA/processed/alerts.csv
export TC_HISTORICAL=$TC_DATA/historical.csv

export TC_EDGE_THRESHOLD=0.04
export TC_MIN_CONFIDENCE=0.55
export TC_MAX_ALERTS=50
