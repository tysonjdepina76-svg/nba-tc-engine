# tc_dashboard.py — 6 tabs, reads SQLite directly (matches real schema)
import streamlit as st
import sqlite3
import pandas as pd
from pathlib import Path

DB_PATH = Path(__file__).parent / "data" / "picks.db"

st.set_page_config(page_title="TC Sports App", page_icon="🏆", layout="wide")

# ── Sidebar widgets ──────────────────────────────────────────────
def health_widget():
    st.sidebar.subheader("🩺 System Health")
    try:
        import requests
        resp = requests.get("http://localhost:8000/api/v1/system/health", timeout=2)
        if resp.status_code == 200:
            st.sidebar.success("✅ All services OK")
        else:
            st.sidebar.warning("⚠️ API degraded")
    except:
        st.sidebar.warning("⚠️ API not reachable (dashboard reads DB directly)")

def side_stats():
    if DB_PATH.exists():
        conn = sqlite3.connect(str(DB_PATH))
        total = conn.execute("SELECT COUNT(*) FROM picks").fetchone()[0]
        edges = conn.execute("SELECT AVG(edge) FROM picks").fetchone()[0]
        conn.close()
        st.sidebar.metric("Total Picks", f"{total:,}")
        if edges:
            st.sidebar.metric("Avg Edge", f"{edges:.2f}%")

# ── Tab functions ────────────────────────────────────────────────
def picks_tab():
    st.subheader("📋 Live +EV Picks")
    if not DB_PATH.exists():
        st.warning("No picks database. Run: python daily_picks.py --sport all")
        return
    conn = sqlite3.connect(str(DB_PATH))
    df = pd.read_sql_query("""
        SELECT player, league AS sport, team, stat, tc_projection, market_line, edge, direction, reason, matchup, period, signal
        FROM picks
        ORDER BY edge DESC
        LIMIT 50
    """, conn)
    conn.close()
    if df.empty:
        st.warning("No picks. Run: python daily_picks.py --sport all")
    else:
        st.caption(f"Showing {len(df)} picks")
        st.dataframe(df, use_container_width=True)

def investor_tab():
    st.header("📈 Investor Dashboard")
    if not DB_PATH.exists():
        st.info("No database yet. Run daily_picks.py first.")
        return
    conn = sqlite3.connect(str(DB_PATH))
    # Win rate by league + direction
    df = pd.read_sql_query("""
        SELECT league AS sport, direction, COUNT(*) AS total,
               ROUND(AVG(edge), 2) AS avg_edge
        FROM picks
        GROUP BY league, direction
        ORDER BY league, direction
    """, conn)
    if not df.empty:
        st.subheader("📊 Picks by League & Direction")
        st.dataframe(df, use_container_width=True)

    # Top players by edge
    df_top = pd.read_sql_query("""
        SELECT player, league AS sport, stat, edge, direction
        FROM picks
        ORDER BY edge DESC
        LIMIT 15
    """, conn)
    if not df_top.empty:
        st.subheader("🔥 Top 15 Picks by Edge")
        st.dataframe(df_top, use_container_width=True)
    conn.close()

def accuracy_tab():
    st.header("🎯 Projection Accuracy")
    st.info("Accuracy tab activates once picks are graded. Data will flow from graded_picks table.")

def live_tab():
    st.header("⚡ Live Games")
    if not DB_PATH.exists():
        st.info("No data.")
        return
    conn = sqlite3.connect(str(DB_PATH))
    matchups = conn.execute("SELECT DISTINCT matchup, league FROM picks ORDER BY league").fetchall()
    conn.close()
    if matchups:
        st.subheader("Today's Matchups")
        for m, l in matchups:
            st.write(f"**{l}**: {m}")
    else:
        st.info("No matchups yet.")

def combo_tab():
    st.header("🔗 Combo Builder")
    st.info("Combo builder activates when picks + DK lines are available.")

def edge_analysis_tab():
    st.header("🧠 Edge Analysis")
    if not DB_PATH.exists():
        st.info("No explained picks available. Run daily_picks.py first.")
        return
    conn = sqlite3.connect(str(DB_PATH))
    df = pd.read_sql_query("""
        SELECT player, league AS sport, stat, tc_projection, market_line, edge, direction, reason, signal
        FROM picks
        WHERE reason IS NOT NULL
        ORDER BY edge DESC
        LIMIT 50
    """, conn)
    conn.close()
    if df.empty:
        st.info("No explained picks available.")
    else:
        for _, row in df.iterrows():
            sig = row.get("signal", "")
            badge = {"STRONG":"🟢","MODERATE":"🟡","WEAK":"🔴","PROJECTION ONLY":"⚪"}.get(sig, "⚪")
            st.markdown(f"""
            {badge} **{row['player']}** ({row['sport']} {row['stat']}) — Edge: **{row['edge']}%** {row['direction']}
            > 📝 *{row['reason']}*
            ---
            """)

# ── Main ─────────────────────────────────────────────────────────
def main():
    st.title("🏆 TC Sports App")
    health_widget()
    side_stats()

    tabs = st.tabs(["📋 Picks", "📈 Investor", "🎯 Accuracy", "⚡ Live", "🔗 Combos", "🧠 Edge Analysis"])
    with tabs[0]: picks_tab()
    with tabs[1]: investor_tab()
    with tabs[2]: accuracy_tab()
    with tabs[3]: live_tab()
    with tabs[4]: combo_tab()
    with tabs[5]: edge_analysis_tab()

if __name__ == "__main__":
    main()
